{
  "name": "raphael",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "jill run '(prisma:generate // prisma:deploy // codegen) && build:next'",
    "build:next": "next build",
    "codegen": "graphql-codegen -r dotenv/config -c graphql.config.yml",
    "codegen:check": "yarn codegen --check",
    "codegen:watch": "yarn codegen --watch",
    "dev": "next dev",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint",
    "prisma": "prisma",
    "prisma:deploy": "yarn prisma migrate deploy",
    "prisma:generate": "yarn prisma generate",
    "start": "next start"
  },
  "dependencies": {
    "@emotion/cache": "11.14.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "9.2.0",
    "@mui/material": "9.2.0",
    "@mui/material-nextjs": "9.1.1",
    "@octokit/app": "16.1.2",
    "@octokit/webhooks": "14.2.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@sentry/nextjs": "10.65.0",
    "@vercel/analytics": "2.0.1",
    "clsx": "2.1.1",
    "dayjs": "1.11.21",
    "graphql": "16.14.2",
    "kyrielle": "2.8.3",
    "next": "16.2.10",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "7.2.0",
    "@graphql-codegen/typescript": "6.1.0",
    "@graphql-codegen/typescript-operations": "6.1.0",
    "@graphql-eslint/eslint-plugin": "4.4.0",
    "@jujulego/jill": "3.0.10",
    "@microsoft/eslint-formatter-sarif": "3.1.0",
    "@parcel/watcher": "2.5.6",
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "10.1.8",
    "jiti": "2.7.0",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.0",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.1",
    "typescript": "6.0.3"
  },
  "packageManager": "yarn@4.17.1"
}
